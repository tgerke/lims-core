{
  "name": "lims-core",
  "private": true,
  "version": "0.1.0",
  "description": "A modern, open-source Laboratory Information Management System for clinical research biobanking and analytical labs",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "pnpm -r --parallel typecheck",
    "test": "pnpm -r --parallel test",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "dev": "pnpm -r --parallel dev",
    "screenshots": "node scripts/screenshots.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "playwright": "^1.49.0",
    "typescript": "^5.6.0"
  }
}
